---
import Hr from "./Hr.astro";
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconTool from "@/assets/icons/IconTool.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<header>
  <a
    id="skip-to-content"
    href="#main-content"
    class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
  >
    Skip to content
  </a>
  <div
    id="nav-container"
    class="mx-auto flex max-w-app flex-col items-center justify-between sm:flex-row"
  >
    <div
      id="top-nav-wrap"
      class="relative flex w-full items-baseline justify-between bg-background p-4 sm:items-center sm:py-6"
    >
      <a
        href="/"
        class="absolute py-1 text-xl leading-8 font-semibold whitespace-nowrap sm:static sm:my-auto sm:text-2xl sm:leading-none"
      >
        {SITE.title}
      </a>
      <nav
        id="nav-menu"
        class="flex w-full flex-col items-center sm:ms-2 sm:flex-row sm:justify-end sm:space-x-4 sm:py-0"
      >
        <button
          id="menu-btn"
          class="focus-outline self-end p-2 sm:hidden"
          aria-label="Open Menu"
          aria-expanded="false"
          aria-controls="menu-items"
        >
          <IconX id="close-icon" class="hidden" />
          <IconMenuDeep id="menu-icon" />
        </button>
        <ul
          id="menu-items"
          class:list={[
            "mt-4 grid w-44 grid-cols-2 place-content-center gap-2",
            "[&>li>a]:block [&>li>a]:px-4 [&>li>a]:py-3 [&>li>a]:text-center [&>li>a]:font-medium [&>li>a]:hover:text-accent sm:[&>li>a]:px-2 sm:[&>li>a]:py-1",
            "hidden",
            "sm:mt-0 sm:flex sm:w-auto sm:gap-x-5 sm:gap-y-0",
          ]}
        >
          <li class="col-span-2 relative group">
            <button 
              class="projects-dropdown-btn block px-4 py-3 text-center font-medium hover:text-accent sm:px-2 sm:py-1 cursor-pointer"
              aria-expanded="false"
              aria-haspopup="true"
            >
              Projects
              <svg class="inline-block w-3 h-3 ml-1 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div class="projects-dropdown hidden absolute left-1/2 -translate-x-1/2 top-full pt-2 w-64 z-50">
              <div class="bg-background border border-border rounded-lg shadow-lg overflow-hidden">
              <a 
                href="https://github.com/sanathks/siren" 
                target="_blank" 
                rel="noopener noreferrer"
                class="flex items-start gap-3 px-4 py-3 hover:bg-muted transition-colors"
              >
                <img src="/assets/siren-icon.png" alt="Siren" class="w-8 h-8 mt-0.5" />
                <div>
                  <span class="font-medium text-foreground">Siren</span>
                  <p class="text-sm text-foreground/70 mt-0.5">Diagram & flowchart tool</p>
                </div>
              </a>
              <a 
                href="https://github.com/sanathks/rewrite" 
                target="_blank" 
                rel="noopener noreferrer"
                class="flex items-start gap-3 px-4 py-3 hover:bg-muted transition-colors border-t border-border"
              >
                <img src="/assets/rewrite-icon.png" alt="Rewrite" class="w-8 h-8 mt-0.5" />
                <div>
                  <span class="font-medium text-foreground">Rewrite</span>
                  <p class="text-sm text-foreground/70 mt-0.5">macOS grammar fixer with local LLMs</p>
                </div>
              </a>
              </div>
            </div>
          </li>
          <li class="col-span-2">
            <a href="/posts" class:list={{ "active-nav": isActive("/posts") }}>
              Posts
            </a>
          </li>
          <li class="col-span-2">
            <a href="/tags" class:list={{ "active-nav": isActive("/tags") }}>
              Tags
            </a>
          </li>
          <li class="col-span-2 relative group">
            <button 
              class="tools-dropdown-btn focus-outline flex justify-center p-3 sm:p-1 cursor-pointer hover:[&>svg]:stroke-accent"
              aria-expanded="false"
              aria-haspopup="true"
              aria-label="Tools"
              title="Tools"
            >
              <IconTool class="hidden sm:inline-block" />
              <span class="sm:hidden font-medium">Tools</span>
            </button>
            <div class="tools-dropdown hidden absolute left-1/2 -translate-x-1/2 top-full pt-2 w-64 z-50">
              <div class="bg-background border border-border rounded-lg shadow-lg overflow-hidden">
              <a 
                href="https://siren.sanath.dev" 
                target="_blank" 
                rel="noopener noreferrer"
                class="flex items-start gap-3 px-4 py-3 hover:bg-muted transition-colors"
              >
                <img src="/assets/siren-icon.png" alt="Siren" class="w-8 h-8 mt-0.5" />
                <div>
                  <span class="font-medium text-foreground">Siren</span>
                  <p class="text-sm text-foreground/70 mt-0.5">Try the live diagram tool</p>
                </div>
              </a>
              </div>
            </div>
          </li>
          <li class="col-span-1 flex items-center justify-center">
            <LinkButton
              href="/search"
              class:list={[
                "focus-outline flex p-3 sm:p-1",
                { "[&>svg]:stroke-accent": isActive("/search") },
              ]}
              ariaLabel="search"
              title="Search"
            >
              <IconSearch />
              <span class="sr-only">Search</span>
            </LinkButton>
          </li>
          {
            SITE.lightAndDarkMode && (
              <li class="col-span-1 flex items-center justify-center">
                <button
                  id="theme-btn"
                  class="focus-outline relative size-12 p-4 sm:size-8 hover:[&>svg]:stroke-accent"
                  title="Toggles light & dark"
                  aria-label="auto"
                  aria-live="polite"
                >
                  <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                  <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                </button>
              </li>
            )
          }
        </ul>
      </nav>
    </div>
  </div>
  <Hr />
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  function setupDropdown(btnSelector: string, dropdownSelector: string) {
    const btn = document.querySelector(btnSelector);
    const dropdown = document.querySelector(dropdownSelector);
    
    if (!btn || !dropdown) return;

    // Toggle on click
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const isOpen = !dropdown.classList.contains("hidden");
      dropdown.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", isOpen ? "false" : "true");
    });

    // Close when clicking outside
    document.addEventListener("click", (e) => {
      if (!btn.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
        dropdown.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      }
    });

    // Show on hover (desktop)
    const parent = btn.parentElement;
    if (parent) {
      parent.addEventListener("mouseenter", () => {
        if (window.innerWidth >= 640) {
          dropdown.classList.remove("hidden");
          btn.setAttribute("aria-expanded", "true");
        }
      });
      parent.addEventListener("mouseleave", () => {
        if (window.innerWidth >= 640) {
          dropdown.classList.add("hidden");
          btn.setAttribute("aria-expanded", "false");
        }
      });
    }
  }

  toggleNav();
  setupDropdown(".projects-dropdown-btn", ".projects-dropdown");
  setupDropdown(".tools-dropdown-btn", ".tools-dropdown");

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", () => {
    toggleNav();
    setupDropdown(".projects-dropdown-btn", ".projects-dropdown");
    setupDropdown(".tools-dropdown-btn", ".tools-dropdown");
  });
</script>
